{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER.databaseasp.net;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "JWT": {
    "ValidAudience": "https://your-api.monsterasp.net",
    "ValidIssuer": "https://your-api.monsterasp.net",
    "Secret": "YOUR_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-frontend-domain.com",
      "http://localhost:5500",
      "http://127.0.0.1:5500",
      "https://localhost:7066"
    ]
  }
}
